generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  isAdmin   Boolean  @default(false)
  isVerified Boolean @default(false)
  isSuspended Boolean @default(false)
  password   String?
  googleId   String?  @unique
  facebookId String?  @unique
  slug      String   @unique
  avatarUrl String?
  favoritePromotion String?
  predictionScore Int @default(0)  // count of correct predictions (resolved)
  predictionCount Int @default(0)  // count of all resolved predictions
  needsUsernameSetup Boolean @default(false)
  profileThemeEventId String?
  profileThemeEvent   Event?   @relation("ProfileTheme", fields: [profileThemeEventId], references: [id])
  createdAt DateTime @default(now())

  // Relations
  reviews       Review[]
  WatchListItem WatchListItem[]
  Reply         Reply[]
  predictions   Prediction[]
  liveComments  LiveComment[]

  followers     Follow[]       @relation("followers")
  following     Follow[]       @relation("following")
  MatchRating   MatchRating[]
  ReviewVote    ReviewVote[]
  lists         List[]
  notifications Notification[]
  favoriteMatches   FavoriteMatch[]
  pollVotes         PollVote[]
  eventSubmissions  EventSubmission[]
}

model FavoriteMatch {
  id        String   @id @default(cuid())
  userId    String
  matchId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, matchId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "reply" | "review"
  message   String
  detail    String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Follow {
  id          String   @id @default(cuid())
  follower    User     @relation("followers", fields: [followerId], references: [id])
  followerId  String
  following   User     @relation("following", fields: [followingId], references: [id])
  followingId String
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
}

model Event {
  id            String          @id @default(cuid())
  title         String
  slug          String          @unique
  date          DateTime
  promotion     String
  venue         String?
  city          String?
  attendance    Int?
  network       String?
  wikiUrl       String?
  aewUrl        String?
  posterUrl     String?
  description   String?
  type          String?
  tmdbId        Int?
  profightdbUrl String?
  startTime     DateTime?
  endTime       DateTime?
  currentMatchOrder Int? @default(1)
  enableWatchParty  Boolean  @default(true)
  enablePredictions Boolean  @default(true)
  submittedByUserId String?  // set when event was approved from a user submission
  createdAt     DateTime        @default(now())
  matches       Match[]
  reviews       Review[]
  WatchListItem WatchListItem[]
  listItems     ListItem[]
  themedUsers   User[] @relation("ProfileTheme")
  liveComments  LiveComment[]
  polls         Poll[]
}

model Match {
  id           String             @id @default(cuid())
  order        Int?               @default(1)
  title        String
  result       String?
  rating       Float?
  duration     Int?
  type         String?
  eventId      String
  event        Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  participants MatchParticipant[]
  ratings      MatchRating[]
  favoritedBy  FavoriteMatch[]
  predictions  Prediction[]
  listItems    ListItem[]
  createdAt    DateTime           @default(now())
}

model MatchRating {
  id        String   @id @default(cuid())
  rating    Float
  userId    String
  matchId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([userId, matchId])
}

model Review {
  id        String       @id @default(cuid())
  rating    Float
  comment   String?
  userId    String
  eventId   String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())
  Reply     Reply[]
  votes     ReviewVote[]

  @@unique([userId, eventId])
}

model WatchListItem {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId   String
  watchlist Boolean  @default(true)
  watched   Boolean  @default(false)
  attended  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([userId, eventId])
}

model Reply {
  id        String   @id @default(cuid())
  comment   String
  createdAt DateTime @default(now())
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reviewId  String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
}

model Wrestler {
  id        String             @id @default(cuid())
  name      String
  slug      String             @unique
  imageUrl  String?
  bio       String?
  matches   MatchParticipant[]
  aliases   WrestlerAlias[]
  createdAt DateTime           @default(now())
}

model WrestlerAlias {
  id         String   @id @default(cuid())
  alias      String
  wrestlerId String
  wrestler   Wrestler @relation(fields: [wrestlerId], references: [id], onDelete: Cascade)

  @@index([wrestlerId])
}

model MatchParticipant {
  id         String   @id @default(cuid())
  matchId    String
  match      Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  wrestlerId String
  wrestler   Wrestler @relation(fields: [wrestlerId], references: [id], onDelete: Cascade)
  team       Int?
  isWinner   Boolean?
}

model SiteConfig {
  key   String @id
  value String
}

model MediaItem {
  id          String   @id @default(cuid())
  filename    String
  url         String
  mimeType    String?
  size        Int?
  uploadedBy  String?
  createdAt   DateTime @default(now())
}

model Promotion {
  id        String            @id @default(cuid())
  shortName String            @unique
  fullName  String?
  logoUrl   String?
  createdAt DateTime          @default(now())
  aliases   PromotionAlias[]
}

model PromotionAlias {
  id          String    @id @default(cuid())
  fullName    String    @unique
  promotionId String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
}

model ReviewVote {
  id        String   @id @default(cuid())
  userId    String
  reviewId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, reviewId])
}

model List {
  id          String     @id @default(cuid())
  title       String
  description String?
  isPublic    Boolean    @default(true)
  listType    String     @default("events")
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       ListItem[]
  createdAt   DateTime   @default(now())
}

model ListItem {
  id        String   @id @default(cuid())
  listId    String
  list      List     @relation(fields: [listId], references: [id], onDelete: Cascade)
  eventId   String?
  event     Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  matchId   String?
  match     Match?   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  note      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([listId, eventId])
  @@unique([listId, matchId])
}

model Poll {
  id        String       @id @default(cuid())
  question  String
  isActive  Boolean      @default(false)
  eventId   String?
  event     Event?       @relation(fields: [eventId], references: [id], onDelete: SetNull)
  endsAt    DateTime?
  createdAt DateTime     @default(now())
  options   PollOption[]
  votes     PollVote[]
}

model PollOption {
  id     String     @id @default(cuid())
  pollId String
  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  text   String
  order  Int        @default(0)
  votes  PollVote[]
}

model PollVote {
  id       String     @id @default(cuid())
  pollId   String
  poll     Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  optionId String
  option   PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  userId   String
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([pollId, userId])
}

model Prediction {
  id                String   @id @default(cuid())
  userId            String
  matchId           String
  predictedWinnerId String?  // ID of the wrestler predicted to win
  isCorrect         Boolean? // null = unresolved, true/false = result set
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  match             Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
}

model EventSubmission {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Core event fields
  title           String
  date            DateTime
  promotion       String
  venue           String?
  city            String?
  attendance      Int?
  network         String?
  posterUrl       String?
  description     String?
  type            String?
  sourceUrl       String   // e.g. Cagematch / Wikipedia link for verification

  // Moderation
  status          String   @default("pending") // pending | approved | rejected
  rejectionReason String?
  approvedEventId String?  // set after approval

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model LiveComment {
  id        String   @id @default(cuid())
  text      String
  userId    String
  eventId   String
  matchId   String?  // Optional: link comment to a specific match happening now
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}
